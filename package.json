{
  "name": "purranormal-activity",
  "version": "0.14.15",
  "private": true,
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "preview": "vite preview",
    "deploy": "pnpm run build:start && wrangler deploy --config dist/server/wrangler.json",
    "dev": "pnpm run increase && vite dev",
    "build": "pnpm run build:start",
    "build:start": "vite build",
    "start": "vite preview",
    "cf-typegen": "wrangler types --config wrangler.jsonc",
    "lint": "biome check .",
    "format": "biome format . --write",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "generate": "pnpm run increase && npx drizzle-kit push",
    "increase": "npm --no-git-tag-version version patch",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@aws-sdk/client-s3": "3.1045.0",
    "@libsql/client": "^0.17.3",
    "@tabler/icons-react": "^3.44.0",
    "ai": "^6.0.177",
    "classnames": "^2.5.1",
    "drizzle-orm": "^0.45.2",
    "nuqs": "^2.8.9",
    "openai": "^6.37.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-intersection-observer": "^10.0.3",
    "sort-es": "^1.7.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@cloudflare/vite-plugin": "1.36.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.65",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "8.0.12",
    "vitest": "^4.1.6",
    "wrangler": "4.90.1"
  }
}
